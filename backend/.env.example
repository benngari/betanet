# Server
PORT=4000

# M-Pesa Daraja (https://developer.safaricom.co.ke)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Must be a public HTTPS URL Safaricom can reach (use ngrok while testing locally)
MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa-callback

# MikroTik RouterOS API
MIKROTIK_HOST=192.168.88.1
MIKROTIK_USER=betanet-api
MIKROTIK_PASSWORD=
MIKROTIK_PORT=8728
MIKROTIK_USE_TLS=false
